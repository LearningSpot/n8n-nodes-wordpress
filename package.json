{
	"name": "n8n-nodes-wordpress",
	"version": "0.1.0",
	"description": "This wordpress node adds advanced Post, Page, and User operations to n8n with features that the official WordPress node does not provide.",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package", "Wordpress", "n8n",  "LearningSpot"
	],
	"author": {
		"name": "LearningSpot",
		"email": ""
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/LearningSpot/n8n-nodes-wordpress.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/WordpressApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Wordpress/Wordpress.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
